<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Curseur arc-en-ciel</title>
  <style>
    body {
      margin: 0;
      height: 200vh;
      cursor: none; /* on cache le curseur normal */
      background: #111;
    }

    /* Curseur personnalisé */
    .cursor {
      position: fixed;
      width: 32px;
      height: 32px;
      background: url('curseur.png') no-repeat center/contain;
      pointer-events: none;
      transform: translate(-50%, -50%);
      z-index: 9999;
    }

    /* Particules arc-en-ciel */
    .trail {
      position: fixed;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      opacity: 0.8;
      animation: fadeOut 0.8s linear forwards;
    }

    @keyframes fadeOut {
      to {
        opacity: 0;
        transform: scale(0.5);
      }
    }
  </style>
</head>
<body>

<div class="cursor"></div>

<script>
  const cursor = document.querySelector('.cursor');

  const colors = [
    '#ff0000','#ff7f00','#ffff00',
    '#00ff00','#0000ff','#4b0082','#9400d3'
  ];

  let colorIndex = 0;

  document.addEventListener('mousemove', (e) => {
    // déplacer le curseur
    cursor.style.left = e.clientX + 'px';
    cursor.style.top = e.clientY + 'px';

    // créer une particule
    const trail = document.createElement('div');
    trail.classList.add('trail');

    trail.style.left = e.clientX + 'px';
    trail.style.top = e.clientY + 'px';
    trail.style.backgroundColor = colors[colorIndex];

    document.body.appendChild(trail);

    // cycle des couleurs
    colorIndex = (colorIndex + 1) % colors.length;

    // supprimer après animation
    setTimeout(() => {
      trail.remove();
    }, 800);
  });
</script>

</body>
</html>
