<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Pourcentage</title>
  <style>
    body {
        #CSS
      font-family: Arial, sans-serif;
      margin: 0;
      background: #f5f7fa;
    }

    section {
      padding: 100px 20px;
      text-align: center;
    }

    h2 {
      margin-bottom: 50px;
      font-size: 2.5rem;
    }

    .stats {
      display: flex;
      justify-content: center;
      gap: 50px;
      flex-wrap: wrap;
    }

    .stat {
      background: white;
      padding: 30px;
      border-radius: 15px;
      width: 150px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .number {
      font-size: 3rem;
      font-weight: bold;
      color: #2c7be5;
    }

    .label {
      margin-top: 10px;
      color: #555;
    }
  </style>
</head>
<body>

<section>
  <h2>Lycée en chiffres</h2>

  <div class="stats">
    <div class="stat">
      <div class="number" data-target="94">0</div>
      <div class="label">De réussite au bac</div>
    </div>

    <div class="stat">
      <div class="number" data-target="8">0</div>
      <div class="label">Formations Post-Bacs</div>
    </div>

    <div class="stat">
      <div class="number" data-target="1160">0</div>
      <div class="label">Élèves et étudiants</div>
    </div>
  </div>
</section>

<script>
  const counters = document.querySelectorAll('.number');
  let started = false;

  function animateCounters() {
    counters.forEach(counter => {
      const target = +counter.dataset.target;
      const duration = 1200;
      const startTime = performance.now();

      function update(time) {
        const progress = Math.min((time - startTime) / duration, 1);
        
        // easing (accélération douce)
        const easeOut = 1 - Math.pow(1 - progress, 3);

        counter.textContent = Math.floor(easeOut * target);

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          counter.textContent = target;
        }
      }

      requestAnimationFrame(update);
    });
  }

  // déclenchement au scroll
  const observer = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting && !started) {
      animateCounters();
      started = true;
    }
  });

  observer.observe(document.querySelector('.stats'));
</script>

</body>
</html>
